{
    "servers": {
        "io.github.upstash/context7": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "@upstash/context7-mcp@latest"
            ],
            "env": {
                "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
            }
        },
        "io.github.github/github-mcp-server": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/"
        }
    },
    "inputs": [
        {
            "id": "CONTEXT7_API_KEY",
            "type": "promptString",
            "description": "API key for authentication",
            "password": true
        }
    ]
}
